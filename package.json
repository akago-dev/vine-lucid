{
  "name": "@akago/vine-lucid",
  "version": "0.2.0",
  "description": "Generate a vine schema based on a lucid model definition",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akago-dev/vine-lucid.git"
  },
  "keywords": [
    "vine",
    "lucid",
    "model",
    "orm",
    "validation",
    "adonisjs",
    "adonis"
  ],
  "author": "AKAGO",
  "license": "SEE LICENCE IN LICENCE",
  "bugs": {
    "url": "https://github.com/akago-dev/vine-lucid/issues"
  },
  "homepage": "https://github.com/akago-dev/vine-lucid#readme",
  "main": "./build/index.js",
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests",
    "!build/.vscode"
  ],
  "exports": {
    ".": "./build/index.js",
    "./vine_lucid_provider": "./build/providers/vine_lucid_provider.js"
  },
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "clean": "del-cli build",
    "precompile": "npm run lint && npm run clean",
    "compile": "tsup-node && tsc --emitDeclarationOnly --declaration",
    "build": "npm run compile",
    "version": "npm run build",
    "prepublishOnly": "npm run build",
    "release": "npx release-it",
    "test:debug": "nodemon --watch ./ -e ts --exec \"node --loader ts-node/esm --inspect bin/test.ts \"",
    "test": "node --loader ts-node/esm --inspect bin/test.ts"
  },
  "dependencies": {
    "@poppinss/macroable": "^1.1.0"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/lucid": "^22.0.0",
    "@vinejs/vine": "^4.3.0",
    "luxon": "^3.7.1"
  },
  "devDependencies": {
    "@adonisjs/core": "^7.0.1",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/expect-type": "^2.0.4",
    "@japa/runner": "^5.3.0",
    "@swc/core": "^1.15.18",
    "@types/node": "^25.3.5",
    "del-cli": "^7.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "eslintConfig": {
    "extends": "@adonisjs/eslint-config/package"
  },
  "prettier": "@adonisjs/prettier-config",
  "tsup": {
    "entry": [
      "./index.ts",
      "./providers/vine_lucid_provider.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "dts": false,
    "sourcemap": false,
    "target": "esnext"
  }
}
